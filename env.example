# AWS Configuration
# Used for accessing AWS Bedrock for LLM operations
AWS_PROFILE=default
AWS_REGION=us-east-1

# Optional: Override specific Bedrock models
# These are the defaults if not specified in config.yaml
# BEDROCK_MODEL_PRIMARY=anthropic.claude-sonnet-4-6-v1:0
# BEDROCK_MODEL_RESEARCH=anthropic.claude-sonnet-4-6-v1:0
# BEDROCK_MODEL_GENERATION=anthropic.claude-haiku-4-5-v1:0
